{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "databricks-claude --headless-ensure",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "databricks-claude --headless-release",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
